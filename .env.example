# SAENA FORGE — example environment variable NAMES only.
# Do NOT put real secrets here. Status: PROPOSED placeholders.

# Tenancy (internal-k3s may use a fixed tenant_id)
SAENA_TENANT_ID=
SAENA_WORKSPACE_ID=
SAENA_PROJECT_ID=
SAENA_SITE_ID=

# Deployment profile: development | internal-k3s | saas-shared | saas-dedicated
SAENA_DEPLOYMENT_PROFILE=development

# Engine feature flags (v1)
SAENA_ENGINE_CHATGPT_SEARCH=true
SAENA_ENGINE_GOOGLE_AI_OVERVIEWS=false
SAENA_ENGINE_GOOGLE_AI_MODE=false
SAENA_ENGINE_GEMINI=false

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=saena-forge

# External refs (names only — values via secret broker)
# SAENA_POSTGRES_DSN=   # secret
# SAENA_OBJECT_STORAGE_URI=  # secret
# SAENA_MODEL_API_KEY=  # secret — never in agent prompt
