[importlinter]
root_packages =
    saena_shared
    saena_testing
    saena_schemas
    saena_domain
    saena_observability
    saena_tenant_control
    saena_policy_gate
    saena_audit_ledger
    saena_plan_contract
    saena_forge_console
    saena_orchestrator
    saena_artifact_registry
    saena_engine_gateway

; dependency-policy Allowed directions (W0 minimal form, extended by w2-00).
; Allowed import directions (ADR-0002 rule 11 / dependency-policy):
;   services -> saena_domain / saena_observability / saena_schemas / saena_shared
;   saena_domain -> saena_schemas / saena_shared
;   saena_observability -> saena_shared
;   saena_shared / saena_schemas are leaves. Services never import each other
;   (service-to-service boundary = published contracts only: events/HTTP).

[importlinter:contract:shared-is-a-leaf]
name = saena_shared must not import other saena packages
type = forbidden
source_modules =
    saena_shared
forbidden_modules =
    saena_testing
    saena_schemas
    saena_domain
    saena_observability
    saena_tenant_control
    saena_policy_gate
    saena_audit_ledger
    saena_plan_contract
    saena_forge_console
    saena_orchestrator
    saena_artifact_registry
    saena_engine_gateway

[importlinter:contract:schemas-is-a-leaf]
name = saena_schemas must not import other saena packages
type = forbidden
source_modules =
    saena_schemas
forbidden_modules =
    saena_shared
    saena_testing
    saena_domain
    saena_observability
    saena_tenant_control
    saena_policy_gate
    saena_audit_ledger
    saena_plan_contract
    saena_forge_console
    saena_orchestrator
    saena_artifact_registry
    saena_engine_gateway

[importlinter:contract:domain-below-services]
name = saena_domain must not import services, observability or testing
type = forbidden
source_modules =
    saena_domain
forbidden_modules =
    saena_testing
    saena_observability
    saena_tenant_control
    saena_policy_gate
    saena_audit_ledger
    saena_plan_contract
    saena_forge_console
    saena_orchestrator
    saena_artifact_registry
    saena_engine_gateway

[importlinter:contract:observability-below-services]
name = saena_observability must not import domain, services or testing
type = forbidden
source_modules =
    saena_observability
forbidden_modules =
    saena_testing
    saena_domain
    saena_tenant_control
    saena_policy_gate
    saena_audit_ledger
    saena_plan_contract
    saena_forge_console
    saena_orchestrator
    saena_artifact_registry
    saena_engine_gateway

[importlinter:contract:services-are-independent]
name = services must not import each other (boundary = published contracts: events/HTTP)
type = independence
modules =
    saena_tenant_control
    saena_policy_gate
    saena_audit_ledger
    saena_plan_contract
    saena_forge_console
    saena_orchestrator
    saena_artifact_registry
    saena_engine_gateway
