[importlinter]
root_packages =
    saena_shared
    saena_testing
    saena_schemas
    saena_domain
    saena_observability
    saena_tenant_control
    saena_policy_gate
    saena_audit_ledger
    saena_plan_contract
    saena_forge_console
    saena_orchestrator
    saena_artifact_registry
    saena_engine_gateway
    saena_repository_intake
    saena_quality_eval
    saena_agent_runner
    saena_chatgpt_observer
    saena_site_discovery
    saena_forgectl
    saena_hooks_runtime
    saena_analytics_clickhouse
    saena_vector_store

; dependency-policy Allowed directions (W0 minimal form, extended by w2-00).
; Allowed import directions (ADR-0002 rule 11 / dependency-policy):
;   services -> saena_domain / saena_observability / saena_schemas / saena_shared
;   saena_domain -> saena_schemas / saena_shared
;   saena_observability -> saena_shared
;   saena_shared / saena_schemas are leaves. Services never import each other
;   (service-to-service boundary = published contracts only: events/HTTP).
;   saena_forgectl (tools/forgectl, w2-19/w2-20) -> saena_schemas only (the
;   v1 EngineId closed enum for its engine-flags preflight check). It is a
;   standalone k3s operator CLI, not a service or a domain/observability
;   dependency — saena_domain, saena_observability, and every service must
;   never import it (forbidden-modules entries below), and it must never
;   import saena_domain or any service (its own leaf contract below).

[importlinter:contract:shared-is-a-leaf]
name = saena_shared must not import other saena packages
type = forbidden
source_modules =
    saena_shared
forbidden_modules =
    saena_testing
    saena_schemas
    saena_domain
    saena_observability
    saena_tenant_control
    saena_policy_gate
    saena_audit_ledger
    saena_plan_contract
    saena_forge_console
    saena_orchestrator
    saena_artifact_registry
    saena_engine_gateway
    saena_repository_intake
    saena_quality_eval
    saena_agent_runner
    saena_chatgpt_observer
    saena_site_discovery

[importlinter:contract:schemas-is-a-leaf]
name = saena_schemas must not import other saena packages
type = forbidden
source_modules =
