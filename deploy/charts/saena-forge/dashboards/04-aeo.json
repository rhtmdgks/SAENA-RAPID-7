          "legendFormat": "treatment {{query_cluster}}"
        },
        {
          "refId": "B",
          "expr": "sum(rate(saena_aeo_citation_observation_total{saena_engine_id=\"$engine_id\", cohort=\"control\"}[1h])) by (query_cluster)",
