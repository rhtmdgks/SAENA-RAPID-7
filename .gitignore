# OS / editor
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/
!.vscode/extensions.json

# Env / secrets
.env
.env.*
!.env.example
*.pem
*.key
secrets/
**/credentials*.json

# Dependencies / builds (when added later)
node_modules/
dist/
build/
.target/
target/
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
coverage/
*.egg-info/

# Lockfile policy (ADR-0009/0010/0021): uv.lock is the committed single lockfile.
# Other ecosystems' lockfiles stay ignored until that ecosystem is adopted by ADR
# (un-ignore per file when adopted — e.g. package-lock.json when contract tooling lands).
pnpm-lock.yaml
yarn.lock
Cargo.lock
poetry.lock
package-lock.json
!tools/contract-lint/package-lock.json

# Runtime / local
.tmp/
.tmp-*/
# .saena/ = MAS runtime coordination state, never committed (ADR-0023);
# still inside secret-scan scope (gitleaks scans the working tree).
.saena/
*.log
.turbo/
.next/

# Terraform / local state (if added)
**/.terraform/
*.tfstate*

# Local tool / agent state
.serena/
# .claude/settings.json is CHECKED IN since W0 (team-wide hook wiring + deny
# rules — ADR-0019). Personal overrides go to settings.local.json (ignored).
.claude/settings.local.json
# Anchored to repo root: local agent-hook logs only (ADR-0019). The previous
# bare 'audit/' also shadowed packages/**/audit/ module dirs (found by w2-04).
/audit/

# Customer source workspaces (never commit)
workspaces/
customer-repos/

# Node toolchain isolation (contract lint only)
tools/contract-lint/node_modules/

# Coverage artifacts (regenerated every test run)
.coverage
coverage.xml
